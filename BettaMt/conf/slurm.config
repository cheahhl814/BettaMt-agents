// ---------------------------------------------------------------------------
// SLURM cluster profile — process-specific resources
// ---------------------------------------------------------------------------
profiles {

    slurm {
        process {
            executor = 'slurm'

            // Long-read (ONT) path
            withName: 'BAIT_MITO' {
                clusterOptions = '--partition=cpu1.medm,cpu2.largem --job-name=bait_mito -o test.out -e test.err'
                cpus   = 24
                memory = '180 GB'
            }
            withName: 'FLYE' {
                clusterOptions = '--partition=cpu1.medm,cpu2.largem --job-name=flye -o test.out -e test.err'
                cpus   = 12
                memory = '64 GB'
            }
            withName: 'GETORGANELLE_FILTER' {
                clusterOptions = '--partition=cpu1,cpu2 --job-name=getOrganelle -o test.out -e test.err'
                cpus   = 6
                memory = '24 GB'
            }

            // Shared rotation / annotation
            withName: 'FIRSTGENE' {
                clusterOptions = '--partition=cpu1,cpu2 --job-name=firstGene -o test.out -e test.err'
                cpus   = 6
                memory = '24 GB'
            }
            withName: 'CIRCLATOR' {
                clusterOptions = '--partition=cpu1,cpu2 --job-name=circlator -o test.out -e test.err'
                cpus   = 6
                memory = '24 GB'
            }

            // Long-read polisher
            withName: 'RACON' {
                clusterOptions = '--partition=cpu1,cpu2 --job-name=polishMt -o test.out -e test.err'
                cpus   = 6
                memory = '24 GB'
            }

            // Short-read (Illumina) path
            withName: 'QC_SHORT' {
                clusterOptions = '--partition=cpu1,cpu2 --job-name=qc_short -o test.out -e test.err'
                cpus   = 8
                memory = '16 GB'
            }
            withName: 'GETORGANELLE_ASM' {
                // SPAdes is the heaviest step — needs both RAM and threads.
                clusterOptions = '--partition=cpu1.medm,cpu2.largem --job-name=getOrgAsm -o test.out -e test.err'
                cpus   = 16
                memory = '96 GB'
            }
            withName: 'POLCA' {
                clusterOptions = '--partition=cpu1,cpu2 --job-name=polca -o test.out -e test.err'
                cpus   = 8
                memory = '32 GB'
            }
        }
    }
}
