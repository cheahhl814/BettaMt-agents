// ===========================================================================
// BettaMt — top-level Nextflow configuration
// ===========================================================================
//
// Profiles:
//   -local    : run on a single workstation, default CPU/memory for laptop
//   -slurm    : submit processes to SLURM with explicit per-process resources
//
// Always applied: conf/base.config
// ===========================================================================

// Disable DSL1-era syntax globally; this pipeline is fully DSL2
nextflow.enable.dsl = 2

profiles {

    standard {
        // No executor override — relies on per-profile block below.
    }

    local {
        process { executor = 'local' }
        includeConfig 'conf/local.config'
    }

    slurm {
        includeConfig 'conf/slurm.config'
    }
}

// Apply base config last so it is overridable by profiles
includeConfig 'conf/base.config'
