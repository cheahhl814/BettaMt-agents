// ---------------------------------------------------------------------------
// Base process defaults — applied to every executor profile unless overridden
// ---------------------------------------------------------------------------
process {
    cpus   = 1
    memory = '4 GB'

    // Sensible default error handling for HPC jobs
    errorStrategy = { task.exitStatus in [104,125,134,137,139,143,255] ? 'retry' : 'terminate' }
    maxRetries    = 2
}
